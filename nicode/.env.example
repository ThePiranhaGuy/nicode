# ========================================
# Nicode - Environment Configuration
# ========================================

# --- Brain Selection ---
# Set the default brain: "azure" or "nvidia"
NICODE_BRAIN=azure

# --- Azure OpenAI Configuration ---
AZURE_OPENAI_API_KEY=your_azure_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=your_deployment_name
AZURE_OPENAI_API_VERSION=2024-06-01

# Enable extended thinking (Azure OpenAI o-series & latest gpt-4o only)
AZURE_THINKING_ENABLED=false

# --- NVIDIA NIM Configuration ---
NVIDIA_NIM_API_KEY=your_nvidia_api_key_here
NVIDIA_NIM_MODEL=nvidia/llama-3.3-nemotron-70b-instruct
# Optional: custom endpoint (defaults to https://integrate.api.nvidia.com/v1/chat/completions)
# NVIDIA_NIM_URL=https://integrate.api.nvidia.com/v1/chat/completions

# --- Optional Settings ---
# Command timeout in seconds (default: 30)
NICODE_TIMEOUT=60

# Memory file location (relative to where you run the script)
# NICODE_MEMORY=.nicode/memory.md